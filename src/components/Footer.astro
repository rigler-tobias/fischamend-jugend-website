---
const base = import.meta.env.BASE_URL;
---

<footer class="club-gradient text-white mt-24">
  <div class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-1 sm:grid-cols-3 gap-10">
    <div>
      <a href={base} class="inline-block mb-3">
        <img src={`${base}images/logo/logo.png`} alt="Fischamender Jugend Logo" class="h-12 w-auto" />
      </a>
      <p class="text-sm text-white/80">
        Ein Jugendverein für soziale und kulturelle Projekte in Fischamend.
      </p>
    </div>

    <div>
      <h5 class="font-semibold text-club-yellow mb-3">Quick Links</h5>
      <ul class="space-y-2 text-sm text-white/80">
        <li><a href={base} class="hover:text-club-yellow transition-colors">Home</a></li>
        <li><a href={`${base}ueber-uns`} class="hover:text-club-yellow transition-colors">Über uns</a></li>
        <li><a href={`${base}vorstand`} class="hover:text-club-yellow transition-colors">Vorstand</a></li>
        <li><a href={`${base}blog`} class="hover:text-club-yellow transition-colors">Blog</a></li>
        <li><a href={`${base}kontakt`} class="hover:text-club-yellow transition-colors">Kontakt</a></li>
      </ul>
    </div>

    <div>
      <h5 class="font-semibold text-club-yellow mb-3">Impressum</h5>
      <p class="text-sm text-white/80 leading-relaxed">
        Tobias Rigler<br />
        Enzersdorfer Straße 32<br />
        2401 Fischamend
      </p>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="max-w-6xl mx-auto px-4 py-4 text-xs text-white/60 text-center">
      &copy; {new Date().getFullYear()} Fischamender Jugend
    </div>
  </div>
</footer>
