---
import Layout from "../layouts/Layout.astro";
const base = import.meta.env.BASE_URL;
---

<Layout title="Fehler 404 | Fischamender Jugend" noindex>
  <section class="club-gradient text-white py-16 text-center">
    <h1 class="text-4xl font-bold">Fehler 404</h1>
  </section>

  <section class="max-w-2xl mx-auto px-4 py-24 text-center">
    <h2 class="text-2xl font-semibold mb-2">Wir konnten die angegebene Seite nicht finden.</h2>
    <p class="text-slate-600 mb-8">Vielleicht findest du sie mit den untenstehenden Links</p>
    <div class="flex justify-center gap-4">
      <a href={base} class="border-2 border-club-blue text-club-blue font-semibold px-6 py-3 rounded-full hover:bg-club-blue hover:text-white transition-colors">Home</a>
      <a href={`${base}blog`} class="bg-club-blue text-white font-semibold px-6 py-3 rounded-full hover:bg-club-blue-dark transition-colors">Blog</a>
    </div>
  </section>
</Layout>
