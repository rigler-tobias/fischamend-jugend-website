---
import Layout from "../layouts/Layout.astro";
const base = import.meta.env.BASE_URL;
---

<Layout title="Fehler 404 | Fischamender Jugend" noindex>
  <section class="relative bg-club-blue-dark text-white py-16 text-center overflow-hidden">
    <div class="blob w-60 h-60 bg-club-yellow/20 -top-16 -right-10"></div>
    <h1 class="relative text-5xl font-bold">Fehler 404 🎣</h1>
  </section>

  <section class="max-w-2xl mx-auto px-4 py-24 text-center">
    <h2 class="font-heading text-2xl font-semibold mb-2">Hoppla, dieser Fisch ist uns entwischt!</h2>
    <p class="text-slate-600 mb-8">Die gesuchte Seite gibt es leider nicht (mehr) – aber hier findest du bestimmt, wonach du suchst.</p>
    <div class="flex justify-center gap-4">
      <a href={base} class="btn-chunky bg-white text-club-blue px-6 py-3">Home</a>
      <a href={`${base}blog`} class="btn-chunky bg-club-blue text-white px-6 py-3">Blog</a>
    </div>
  </section>
</Layout>
