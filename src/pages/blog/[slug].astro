---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL;
const placeholderImage = "/images/placeholder-event.svg";
const mainImage = post.data.image ?? placeholderImage;
const images = post.data.images && post.data.images.length > 0 ? post.data.images : [mainImage];
const mapsUrl = post.data.location
  ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(post.data.location)}`
  : null;

const siteOrigin = (Astro.site ?? new URL("https://fischamender-jugend.at")).origin;
const eventDateStr = post.data.date.toISOString().slice(0, 10);
const eventEndDateStr =
  post.data.endTime && post.data.startTime && post.data.endTime < post.data.startTime
    ? new Date(`${eventDateStr}T00:00:00Z`).valueOf() + 86400000
    : null;
const eventEndDate = eventEndDateStr
  ? new Date(eventEndDateStr).toISOString().slice(0, 10)
  : eventDateStr;
const eventJsonLd = post.data.startTime
  ? {
      "@context": "https://schema.org",
      "@type": "Event",
      name: post.data.title,
      description: post.data.description,
      startDate: `${eventDateStr}T${post.data.startTime}:00+02:00`,
      ...(post.data.endTime && {
        endDate: `${eventEndDate}T${post.data.endTime}:00+02:00`,
      }),
      eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
      eventStatus: "https://schema.org/EventScheduled",
      image: [new URL(mainImage, siteOrigin).toString()],
      location: post.data.location
        ? {
            "@type": "Place",
            name: post.data.location,
            address: post.data.location,
          }
        : undefined,
      organizer: {
        "@type": "Organization",
        name: "Fischamender Jugend",
        url: siteOrigin,
      },
    }
  : null;
---

<Layout title={`${post.data.title} | Fischamender Jugend`} description={post.data.description} image={mainImage}>
  {eventJsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(eventJsonLd)} />
  )}
  <article class="max-w-3xl mx-auto px-4 py-16">
    <a href={`${base}blog`} class="text-sm text-club-blue hover:underline mb-6 inline-block">← Zurück zu allen Events</a>

    {post.data.isFlyer ? (
      <div class="tilt-1 w-full max-h-[70vh] flex items-center justify-center bg-slate-100 rounded-2xl border-4 border-club-dark shadow-2xl mb-8 p-3">
        <img
          src={mainImage}
          alt={post.data.title}
          class="max-h-[65vh] w-auto object-contain rounded-lg"
        />
      </div>
    ) : (
      <img
        src={mainImage}
        alt={post.data.title}
        class="tilt-1 w-full aspect-video object-cover rounded-2xl border-4 border-club-dark shadow-2xl mb-8"
      />
    )}

    <p class="text-sm text-club-blue font-semibold mb-2">
      {post.data.date.toLocaleDateString("de-DE", { day: "2-digit", month: "long", year: "numeric" })}
      {post.data.startTime && (
        <>
          {" · "}
          {post.data.startTime} Uhr{post.data.endTime && ` – ${post.data.endTime} Uhr`}
        </>
      )}
    </p>
    <h1 class="text-3xl md:text-4xl font-bold mb-4">{post.data.title}</h1>

    {post.data.location && (
      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="text-slate-600 text-sm">📍 {post.data.location}</span>
        <a
          href={mapsUrl!}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-chunky bg-club-blue text-white text-sm px-4 py-1.5"
        >
          Route anzeigen
        </a>
      </div>
    )}

    <div class="prose max-w-none prose-a:text-club-blue">
      <Content />
    </div>

    {images.length > 1 && (
      <div class="grid sm:grid-cols-2 gap-4 mt-10">
        {images.slice(1).map((img) => (
          post.data.flyerImages?.includes(img) ? (
            <div class="w-full h-56 bg-slate-100 rounded-xl flex items-center justify-center p-2">
              <img src={img} alt={post.data.title} class="max-h-full max-w-full object-contain rounded-lg" loading="lazy" />
            </div>
          ) : (
            <img src={img} alt={post.data.title} class="w-full h-56 object-cover rounded-xl" loading="lazy" />
          )
        ))}
      </div>
    )}
  </article>
</Layout>
