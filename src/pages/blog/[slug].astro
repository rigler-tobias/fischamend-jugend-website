---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL;
const images = post.data.images && post.data.images.length > 0 ? post.data.images : [post.data.image];
const mapsUrl = post.data.location
  ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(post.data.location)}`
  : null;
---

<Layout title={`${post.data.title} | Fischamender Jugend`} description={post.data.description}>
  <article class="max-w-3xl mx-auto px-4 py-16">
    <a href={`${base}blog`} class="text-sm text-club-blue hover:underline mb-6 inline-block">← Zurück zu allen Events</a>

    <img
      src={post.data.image}
      alt={post.data.title}
      class="w-full aspect-video object-cover rounded-2xl mb-8"
    />

    <p class="text-sm text-club-blue font-semibold mb-2">
      {post.data.date.toLocaleDateString("de-DE", { day: "2-digit", month: "long", year: "numeric" })}
      {post.data.startTime && (
        <>
          {" · "}
          {post.data.startTime} Uhr{post.data.endTime && ` – ${post.data.endTime} Uhr`}
        </>
      )}
    </p>
    <h1 class="text-3xl md:text-4xl font-bold mb-4">{post.data.title}</h1>

    {post.data.location && (
      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="text-slate-600 text-sm">📍 {post.data.location}</span>
        <a
          href={mapsUrl!}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block text-sm border-2 border-club-blue text-club-blue font-semibold px-4 py-1.5 rounded-full hover:bg-club-blue hover:text-white transition-colors"
        >
          Route anzeigen
        </a>
      </div>
    )}

    <div class="prose max-w-none prose-a:text-club-blue">
      <Content />
    </div>

    {images.length > 1 && (
      <div class="grid sm:grid-cols-2 gap-4 mt-10">
        {images.slice(1).map((img) => (
          <img src={img} alt={post.data.title} class="w-full h-56 object-cover rounded-xl" loading="lazy" />
        ))}
      </div>
    )}
  </article>
</Layout>
