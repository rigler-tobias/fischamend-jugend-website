---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Blog | Fischamender Jugend" description="Alle Events und Berichte der Fischamender Jugend.">
  <section class="bg-club-blue text-white py-16 text-center">
    <h1 class="text-4xl font-bold">Fischamender Jugend Events</h1>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => (
        <a href={`${base}blog/${post.id}`} class="group block rounded-2xl overflow-hidden border border-slate-200 hover:shadow-lg transition-shadow">
          <div class="aspect-video overflow-hidden">
            <img
              src={post.data.image}
              alt={post.data.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <div class="p-5">
            <span class="text-xs text-club-blue font-semibold">
              {post.data.date.toLocaleDateString("de-DE", { day: "2-digit", month: "long", year: "numeric" })}
            </span>
            <h2 class="text-lg font-semibold mt-1">{post.data.title}</h2>
            <p class="text-sm text-slate-600 mt-2 line-clamp-3">{post.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
