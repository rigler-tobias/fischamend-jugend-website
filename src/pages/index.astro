---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const latestPosts = posts.slice(0, 3);
---

<Layout title="Fischamender Jugend – Von der Jugend für die Jugend!">
  <!-- Hero -->
  <section id="home" class="relative bg-club-blue text-white overflow-hidden">
    <div class="blob w-72 h-72 bg-club-yellow/20 -top-10 -left-16"></div>
    <div class="blob w-96 h-96 bg-white/10 -bottom-20 -right-20"></div>
    <div class="relative max-w-6xl mx-auto px-4 py-20 md:py-28 grid md:grid-cols-2 gap-10 items-center">
      <div>
        <span class="badge-sticker">Von der Jugend für die Jugend!</span>
        <h1 class="text-4xl md:text-5xl font-bold leading-tight mt-5">
          Fischamender Jugend
        </h1>
        <p class="mt-4 text-white/85 text-lg">
          Wir bringen Fischamend zusammen – mit Events, Projekten und ganz viel guter Laune. Schau vorbei, wir freuen uns auf dich!
        </p>
        <div class="flex flex-wrap gap-4 mt-8">
          <a
            href={`${base}blog`}
            class="btn-chunky bg-club-yellow text-club-dark px-6 py-3"
          >
            Zu den Events
          </a>
          <a
            href={`${base}ueber-uns`}
            class="btn-chunky btn-chunky-white bg-club-blue text-white px-6 py-3"
          >
            Über uns
          </a>
        </div>
      </div>
      <div class="relative">
        <img
          src={`${base}images/hero/hero.jpg`}
          alt="Fischamender Jugend"
          class="tilt-1 rounded-2xl border-4 border-white shadow-2xl w-full h-auto object-cover"
        />
      </div>
    </div>
  </section>

  <!-- Aktuelles / Blog teaser -->
  <section id="events" class="max-w-6xl mx-auto px-4 py-20">
    <div class="text-center mb-12">
      <span class="badge-sticker">Aktuelles</span>
      <h2 class="text-3xl md:text-4xl font-bold mt-4">Unsere Events</h2>
        <p class="text-slate-600 mt-2">Von Punschstand bis Wastedparty – das sind unsere schönsten Momente.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {latestPosts.map((post, i) => (
        <a
          href={`${base}blog/${post.id}`}
          class={`card-sticker group block bg-white overflow-hidden ${i % 2 === 0 ? "tilt-1" : "tilt-2"}`}
        >
          <div class="aspect-video overflow-hidden border-b-2 border-club-dark">
            <img
              src={post.data.image}
              alt={post.data.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <div class="p-5">
            <span class="text-xs text-club-blue font-bold uppercase tracking-wide">
              {post.data.date.toLocaleDateString("de-DE", { day: "2-digit", month: "long", year: "numeric" })}
            </span>
            <h3 class="font-heading text-lg font-semibold mt-1">{post.data.title}</h3>
            <p class="text-sm text-slate-600 mt-2 line-clamp-3">{post.data.description}</p>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-12 flex flex-wrap justify-center gap-4">
      <a href={`${base}blog`} class="btn-chunky bg-white text-club-blue px-6 py-3">
        Alle Events ansehen
      </a>
      <a href={`${base}kalender`} class="btn-chunky bg-club-blue text-white px-6 py-3">
        Zum Kalender
      </a>
    </div>
  </section>

  <!-- Teaser cards to other pages -->
  <section class="bg-slate-50 py-20">
    <div class="max-w-5xl mx-auto px-4 grid sm:grid-cols-3 gap-8">
      <a href={`${base}ueber-uns`} class="card-sticker tilt-2 block bg-white p-8">
        <h3 class="font-heading text-xl font-semibold mb-2">Über uns</h3>
        <p class="text-sm text-slate-600">Lern uns kennen: unsere Geschichte, unsere Werte und wofür unser Herz schlägt.</p>
      </a>
      <a href={`${base}vorstand`} class="card-sticker tilt-1 block bg-white p-8">
        <h3 class="font-heading text-xl font-semibold mb-2">Vorstand</h3>
        <p class="text-sm text-slate-600">Die Köpfe hinter dem Verein – mit ganz viel Herzblut dabei.</p>
      </a>
      <a href={`${base}kalender`} class="card-sticker tilt-3 block bg-white p-8">
        <h3 class="font-heading text-xl font-semibold mb-2">Kalender</h3>
        <p class="text-sm text-slate-600">Kein Fest und keine Aktion mehr verpassen – alle Termine auf einen Blick.</p>
      </a>
    </div>
  </section>
</Layout>
