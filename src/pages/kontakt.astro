---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Kontakt | Fischamender Jugend"
  description="Kontaktiere die Fischamender Jugend – wir freuen uns auf deine Nachricht."
>
  <section class="club-gradient text-white py-16 text-center">
    <h1 class="text-4xl font-bold">Kontakt</h1>
    <p class="mt-3 text-white/85 max-w-xl mx-auto px-4">
      Willst du mitmachen? Kontaktier uns gerne!
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-20 grid md:grid-cols-2 gap-10">
    <div>
      <span class="text-club-blue font-semibold uppercase tracking-wide text-sm">Kontakt</span>
      <h2 class="text-3xl md:text-4xl font-bold mt-2 mb-8">
        Willst du mitmachen?<br />Kontaktier uns gerne!
      </h2>
      <div class="space-y-6 mb-10">
        <div>
          <h3 class="font-semibold">Hier sind wir zu finden</h3>
          <p class="text-slate-600">Jugendzentrum Fischamend,<br />Enzersdorfer Straße 32,<br />2401 Fischamend</p>
        </div>
        <div>
          <h3 class="font-semibold">Schreib uns gerne eine Mail</h3>
          <a href="mailto:kontakt@fischamender-jugend.at" class="text-club-blue hover:underline">kontakt@fischamender-jugend.at</a>
        </div>
      </div>
      <div class="rounded-2xl overflow-hidden border border-slate-200">
        <iframe
          title="Standort Fischamender Jugend"
          src="https://maps.google.com/maps?q=Enzersdorfer%20Stra%C3%9Fe%2032%2C%202401%20Fischamend&t=&z=15&ie=UTF8&iwloc=&output=embed"
          class="w-full h-64"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>

    <div class="bg-slate-50 rounded-2xl p-8 border border-slate-200 h-fit">
      <h3 class="font-semibold text-lg mb-6">Schreib uns eine Nachricht</h3>
      <form
        action="https://formkeep.com/f/1b3b0216e63f"
        accept-charset="UTF-8"
        enctype="multipart/form-data"
        method="POST"
        class="space-y-4"
      >
        <div>
          <label for="fullName" class="block text-sm font-medium mb-1">Vorname Nachname*</label>
          <input type="text" id="fullName" name="fullName" required placeholder="Max Mustermann" class="w-full rounded-lg border border-slate-300 px-4 py-2 focus:outline-none focus:ring-2 focus:ring-club-blue" />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium mb-1">Email*</label>
          <input type="email" id="email" name="email" required placeholder="max.mustermann@example.com" class="w-full rounded-lg border border-slate-300 px-4 py-2 focus:outline-none focus:ring-2 focus:ring-club-blue" />
        </div>
        <div>
          <label for="phone" class="block text-sm font-medium mb-1">Telefonnummer</label>
          <input type="text" id="phone" name="phone" placeholder="+43 660 683552" class="w-full rounded-lg border border-slate-300 px-4 py-2 focus:outline-none focus:ring-2 focus:ring-club-blue" />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium mb-1">Nachricht*</label>
          <textarea id="message" name="message" rows="4" required placeholder="Schreib hier deine Nachricht" class="w-full rounded-lg border border-slate-300 px-4 py-2 focus:outline-none focus:ring-2 focus:ring-club-blue"></textarea>
        </div>
        <button type="submit" class="w-full bg-club-blue text-white font-semibold px-6 py-3 rounded-full hover:bg-club-blue-dark transition-colors">
          Senden
        </button>
      </form>
    </div>
  </section>
</Layout>
